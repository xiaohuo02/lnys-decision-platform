# ═══════════════════════════════════════════════════════════════════════
#  柠优生活大数据平台 · Docker Compose 环境变量模板
#  用法：复制本文件为 .env.docker，填入实际值后使用
#        cp .env.docker.example .env.docker
#        docker compose --env-file .env.docker up -d
#  ⚠️  .env.docker 包含敏感信息，已被 .gitignore 排除
# ═══════════════════════════════════════════════════════════════════════

# ── 运行环境 ──────────────────────────────────────────────────────────
ENV=development
ENABLE_MOCK_DATA=true
# 开发后门开关（仅本地开发使用，生产环境必须为 false）
DEV_BACKDOOR_ENABLED=false

# ── MySQL（docker-compose 服务名，容器内部端口）────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=lnys_user
DB_PASSWORD=<your_mysql_password>
DB_NAME=lnys_db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── PostgreSQL（LangGraph checkpoint，容器内部端口）─────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lnys_user
POSTGRES_PASSWORD=<your_postgres_password>
POSTGRES_DB=lnys_checkpoint

# ── 后端服务 ──────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── 模型路径 ──────────────────────────────────────────────────────────
MODELS_ROOT=./models

# ── 安全密钥（必须替换为强随机字符串）──────────────────────────────────
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<your_secret_key_here>
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM 接入 ──────────────────────────────────────────────────────────
LLM_API_KEY=sk-ce078db286c64dfe8e542c2daa48a4a0
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen3.5-plus-2026-02-15

# ── LangSmith（本地开发可关闭）────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lnys-agent-platform

# ── Mem0（可选）──────────────────────────────────────────────────────
MEM0_API_KEY=

# ── 知识库 Rerank（默认关闭，启用后首次检索会自动下载模型 ~1.1GB）─────
KB_RERANK_ENABLED=false
KB_RERANK_MODEL=BAAI/bge-reranker-base
KB_RERANK_TOP_N=5

# ── MySQL root 密码（docker-compose mysql 服务用）────────────────────
MYSQL_ROOT_PASSWORD=<your_mysql_root_password>
