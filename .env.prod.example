# ═══════════════════════════════════════════════════════════
#  生产环境变量模板
#  复制为 .env.prod 后填写真实值：cp .env.prod.example .env.prod
#  ⚠️  .env.prod 已在 .gitignore，切勿提交到版本库
# ═══════════════════════════════════════════════════════════

ENV=production
ENABLE_MOCK_DATA=false
DEV_BACKDOOR_ENABLED=false

# ── MySQL ────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=lnys_user
DB_PASSWORD=<替换为强密码>
DB_NAME=lnys_db
MYSQL_ROOT_PASSWORD=<替换为 root 强密码>

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<替换为强密码，留空则不设密码>

# ── PostgreSQL (LangGraph checkpoint) ────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=lnys_user
POSTGRES_PASSWORD=<替换为强密码>
POSTGRES_DB=lnys_checkpoint

# ── 安全 ─────────────────────────────────────────────────
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<替换为至少32字符的随机密钥>
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM 接入 ─────────────────────────────────────────────
LLM_API_KEY=sk-ce078db286c64dfe8e542c2daa48a4a0
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen3.5-plus-2026-02-15

# ── CORS（生产域名）─────────────────────────────────────
ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com

# ── 注册授权码 ───────────────────────────────────────────
REGISTER_AUTH_CODE=<替换为企业注册授权码>

# ── 飞书集成（可选）──────────────────────────────────────
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
COPILOT_PATROL_ENABLED=false

# ── Gunicorn Worker 数 (0=auto: CPU*2+1) ────────────────
WORKERS=0
