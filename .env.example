# ═══════════════════════════════════════════════════════════════════════
#  柠优生活大数据平台 · 环境变量模板
#
#  用途说明：
#    本地 Docker Compose 运行：.env.docker （已提交到仓库，安全默认値）
#    云服务器生产部署：cp .env.example .env.prod  然后填写真实密钥
#    本地直跑（非 Docker）：cp .env.example .env  然后调整 DB_HOST=localhost
#
#  关键规则：
#    容器间通信使用服务名： mysql / redis / postgres
#    容器内部端口： 3306 / 6379 / 5432（不是宿主机映射端口）
#    .env.prod / .env.production 已在 .gitignore 排除，不会提交
# ═══════════════════════════════════════════════════════════════════════

# ── 运行环境 ──────────────────────────────────────────────────────────
ENV=development
ENABLE_MOCK_DATA=true

# ── MySQL 组件字段（config.py 会自动构造 DATABASE_URL）──────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=lnys_user
DB_PASSWORD=lnys_password
DB_NAME=lnys_db
# DATABASE_URL=

# ── Redis 组件字段（config.py 会自动构造 REDIS_URL）─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_URL=

# ── PostgreSQL（仅用于 LangGraph checkpoint，不是业务主库）──────────────────
POSTGRES_USER=lnys_user
POSTGRES_PASSWORD=your_pg_password_here
POSTGRES_DB=lnys_checkpoint
# Docker Compose 自动覆盖此 URL （将 host 改为服务名 postgres）
# 本地直跑时保持 localhost:5432
POSTGRES_CHECKPOINT_URL=postgresql://lnys_user:your_pg_password_here@localhost:5432/lnys_checkpoint

# ── 后端服务 ──────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── 模型路径 ──────────────────────────────────────────────────────────
MODELS_ROOT=./models

# ── 安全密钥 / JWT ────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM 接入（兼容 DeepSeek / Qwen / OpenAI）─────────────────────────
# v4.0 开发阶段使用 Qwen (qwen3.5-plus)
LLM_API_KEY=sk-ce078db286c64dfe8e542c2daa48a4a0
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen3.5-plus-2026-02-15
# DeepSeek 替换示例：LLM_BASE_URL=https://api.deepseek.com  LLM_MODEL_NAME=deepseek-chat
# OpenAI 替换示例：LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL_NAME=gpt-4o

# ── LangSmith 可观测性 ───────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=lnys-agent-platform

# ── Mem0 用户记忆（可选）─────────────────────────────────────────────
MEM0_API_KEY=your_mem0_api_key_here

# ── MySQL root 密码（docker-compose mysql 服务初始化用）─────────────────
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here

# ── 飞书集成（OpsCopilot 消息推送 + 群机器人）──────────────────────────
#  1. 在飞书开放平台创建自建应用 → 获取 App ID / App Secret
#  2. 开通权限：im:message:send_as_bot, im:chat:readonly, im:message
#  3. 把机器人拉入目标群 → 运行 python scripts/feishu_list_chats.py 获取 chat_id
#  4. 将 chat_id 填入 feishu_group_mapping 表完成群映射
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENABLED=false

# ── Copilot 定时巡检（依赖飞书推送巡检报告）──────────────────────────
COPILOT_PATROL_ENABLED=false